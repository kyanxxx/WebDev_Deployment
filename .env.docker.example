# Copy to .env (or merge with your existing .env) before: docker compose up -d --build

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change_this_to_a_random_string

APP_PORT=8081
MYSQL_PORT=3306
PHPMYADMIN_PORT=8080

MYSQL_ROOT_PASSWORD=cafe_root_password
MYSQL_DATABASE=cafe_root_db
MYSQL_USER=cafe_root_user
MYSQL_PASSWORD=cafe_password

# Used by docker-compose for the app container (host must be "mysql", not 127.0.0.1)
DATABASE_URL=mysql://cafe_root_user:cafe_password@mysql:3306/cafe_root_db?serverVersion=8.0.32&charset=utf8mb4

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Mailer, OAuth, JWT — set your real values (do not commit secrets)
MAILER_DSN=null://null
MAILER_FROM_ADDRESS=noreply@example.com
MAILER_FROM_NAME="Harvey's Cafe"

JWT_PASSPHRASE=your_jwt_passphrase

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
