{% extends 'base.html.twig' %}

{% block title %}User Management - Admin Dashboard{% endblock %}

{% block page_title %}User Management{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .users-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding: 0 10px;
            width: 100%;
        }

        .users-header h1 {
            font-size: 32px;
            color: #3E2723;
            margin: 0;
            font-weight: 600;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-block;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(139, 90, 60, 0.3);
        }

        .btn-info {
            background-color: #2196F3;
            color: white;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-info:hover {
            background-color: #1976D2;
        }

        .btn-warning {
            background-color: #FF9800;
            color: white;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-warning:hover {
            background-color: #F57C00;
        }

        .btn-danger {
            background-color: #F44336;
            color: white;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-danger:hover {
            background-color: #D32F2F;
        }

        .btn-success {
            background-color: #4CAF50;
            color: white;
            padding: 8px 16px;
            font-size: 14px;
        }

        .btn-success:hover {
            background-color: #388E3C;
        }

        .table-card {
            background: white;
            border: 2px solid #8B5A3C;
            border-radius: 12px;
            padding: 30px;
            overflow-x: auto;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            width: 100%;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 16px;
        }

        thead {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
        }

        thead th {
            padding: 20px 18px;
            text-align: left;
            font-weight: 600;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tbody tr {
            border-bottom: 1px solid #e0e0e0;
            transition: background-color 0.2s ease;
        }

        tbody tr:hover {
            background-color: #f5f5f5;
        }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody td {
            padding: 18px;
            color: #333;
            font-size: 15px;
        }

        .badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            display: inline-block;
        }

        .badge-admin {
            background-color: #F44336;
            color: white;
        }

        .badge-staff {
            background-color: #2196F3;
            color: white;
        }

        .badge-user {
            background-color: #9E9E9E;
            color: white;
        }

        .badge-active {
            background-color: #4CAF50;
            color: white;
        }

        .badge-disabled {
            background-color: #FF9800;
            color: white;
        }

        .badge-archived {
            background-color: #9E9E9E;
            color: white;
        }

        .actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .no-data {
            text-align: center;
            color: #999;
            font-style: italic;
            padding: 40px !important;
        }

        .status-form {
            display: inline-block;
        }

        @media (max-width: 768px) {
            .users-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .table-card {
                padding: 10px;
            }

            thead th, tbody td {
                padding: 10px;
                font-size: 12px;
            }

            .actions {
                flex-direction: column;
            }
        }
    </style>
{% endblock %}

{% block main_content %}
    <div class="users-header">
        <h1>👥 User Management</h1>
        <a href="{{ path('app_user_new') }}" class="btn btn-primary">＋ Create New User</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="flash-message" style="background-color: #4CAF50; color: white; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="flash-message" style="background-color: #F44336; color: white; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-card">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Date Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id }}</td>
                        <td><strong>{{ user.username }}</strong></td>
                        <td>{{ user.email ?? 'N/A' }}</td>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge badge-admin">Admin</span>
                            {% elseif 'ROLE_STAFF' in user.roles %}
                                <span class="badge badge-staff">Staff</span>
                            {% else %}
                                <span class="badge badge-user">User</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.status == 'active' %}
                                <span class="badge badge-active">Active</span>
                            {% elseif user.status == 'disabled' %}
                                <span class="badge badge-disabled">Disabled</span>
                            {% elseif user.status == 'archived' %}
                                <span class="badge badge-archived">Archived</span>
                            {% endif %}
                        </td>
                        <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : 'N/A' }}</td>
                        <td class="actions">
                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-info">View</a>
                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning">Edit</a>
                            
                            {% if user.id != app.user.id %}
                                <form method="post" action="{{ path('app_user_toggle_status', {'id': user.id}) }}" class="status-form" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_status' ~ user.id) }}">
                                    <input type="hidden" name="status" value="{{ user.status == 'active' ? 'disabled' : 'active' }}">
                                    <button type="submit" class="btn {{ user.status == 'active' ? 'btn-warning' : 'btn-success' }}">
                                        {{ user.status == 'active' ? 'Disable' : 'Enable' }}
                                    </button>
                                </form>
                                
                                <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}" class="status-form" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    <button type="submit" class="btn btn-danger">Delete</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="no-data">No users found.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

