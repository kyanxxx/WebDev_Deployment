{% extends 'base.html.twig' %}

{% block title %}Create User - Admin Dashboard{% endblock %}

{% block page_title %}Create New User{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-card {
            background: white;
            border: 2px solid #8B5A3C;
            border-radius: 12px;
            padding: 40px;
            max-width: 980px;
            margin: 0 auto;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 20px 24px;
            align-items: start;
        }

        .form-group {
            margin-bottom: 0;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #3E2723;
            font-size: 16px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #8B5A3C;
        }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .form-actions,
        .full-width {
            grid-column: 1 / -1;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-block;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(139, 90, 60, 0.3);
        }

        .btn-secondary {
            background-color: #9E9E9E;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #757575;
        }

        .error-message {
            color: #F44336;
            font-size: 14px;
            margin-top: 5px;
        }

        .form-errors {
            background-color: #FFEBEE;
            border: 1px solid #F44336;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            color: #C62828;
        }

        @media (max-width: 900px) {
            .form-card {
                max-width: 700px;
                padding: 30px;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block main_content %}
    <div class="form-card">
        {{ form_start(form) }}
        <div class="form-grid">
        
        {% if not form.vars.valid %}
            <div class="form-errors full-width">
                <strong>Please correct the following errors:</strong>
                {{ form_errors(form) }}
            </div>
        {% endif %}

        <div class="form-group">
            {{ form_label(form.username) }}
            {{ form_widget(form.username) }}
            {{ form_errors(form.username) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group">
            {{ form_label(form.roles) }}
            {{ form_widget(form.roles) }}
            {{ form_errors(form.roles) }}
        </div>

        <div class="form-group">
            {{ form_label(form.status) }}
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>

        <div class="form-group">
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword) }}
            {{ form_errors(form.plainPassword) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create User</button>
            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Cancel</a>
        </div>

        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}

