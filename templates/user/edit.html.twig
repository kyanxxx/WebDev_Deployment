{% extends 'base.html.twig' %}

{% block title %}Edit User - Admin Dashboard{% endblock %}

{% block page_title %}Edit User: {{ user.username }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .form-card {
            background: white;
            border: 2px solid #8B5A3C;
            border-radius: 12px;
            padding: 40px;
            max-width: 600px;
            margin: 0 auto;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #3E2723;
            font-size: 16px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #8B5A3C;
        }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-block;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(139, 90, 60, 0.3);
        }

        .btn-secondary {
            background-color: #9E9E9E;
            color: white;
        }

        .btn-secondary:hover {
            background-color: #757575;
        }

        .btn-danger {
            background-color: #F44336;
            color: white;
        }

        .btn-danger:hover {
            background-color: #D32F2F;
        }

        .form-errors {
            background-color: #FFEBEE;
            border: 1px solid #F44336;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            color: #C62828;
        }

        .password-info {
            background-color: #E3F2FD;
            border: 1px solid #2196F3;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            color: #1565C0;
            font-size: 14px;
        }
    </style>
{% endblock %}

{% block main_content %}
    <div class="form-card">
        {{ form_start(form) }}
        
        {% if not form.vars.valid %}
            <div class="form-errors">
                <strong>Please correct the following errors:</strong>
                {{ form_errors(form) }}
            </div>
        {% endif %}

        <div class="password-info">
            <strong>💡 Password Reset:</strong> Leave the password field blank to keep the current password, or enter a new password to reset it.
        </div>

        <div class="form-group">
            {{ form_label(form.username) }}
            {{ form_widget(form.username) }}
            {{ form_errors(form.username) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group">
            {{ form_label(form.roles) }}
            {{ form_widget(form.roles) }}
            {{ form_errors(form.roles) }}
        </div>

        <div class="form-group">
            {{ form_label(form.status) }}
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>

        <div class="form-group">
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword) }}
            {{ form_errors(form.plainPassword) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update User</button>
            <a href="{{ path('app_user_index') }}" class="btn btn-secondary">Cancel</a>
        </div>

        {{ form_end(form) }}
    </div>
{% endblock %}

