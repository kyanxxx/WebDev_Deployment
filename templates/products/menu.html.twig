{% extends 'base.html.twig' %}

{% block title %}Harvey's Café - Menu / Products{% endblock %}

{% block page_title %}Menu / Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .menu-section {
            padding: 30px;
        }

        .menu-section h2 {
            font-size: 28px;
            color: #3E2723;
            margin-bottom: 30px;
            font-weight: 600;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 40px;
            max-width: 1400px;
        }

        .menu-card {
            background: white;
            border: 2px solid #8B5A3C;
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(139, 90, 60, 0.25);
        }

        .menu-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 2px solid #8B5A3C;
        }

        .menu-card-content {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-card h3 {
            font-size: 20px;
            color: #3E2723;
            margin: 0 0 10px 0;
            font-weight: 600;
        }

        .menu-card p {
            font-size: 14px;
            color: #666;
            margin: 0 0 15px 0;
            line-height: 1.5;
            flex-grow: 1;
        }

        .menu-card .price {
            font-size: 22px;
            color: #8B5A3C;
            font-weight: 700;
            margin: 0;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .menu-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 768px) {
            .menu-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }

            .menu-card img {
                height: 150px;
            }
        }

        @media (max-width: 480px) {
            .menu-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

