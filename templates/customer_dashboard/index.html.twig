{% extends 'base.html.twig' %}

{% block title %}Harvey's Cafe - Customer Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .customer-dashboard {
            width: 100%;
            max-width: 1180px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .customer-hero {
            background: linear-gradient(135deg, #6b4e31 0%, #8b4513 55%, #a7693a 100%);
            border-radius: 18px;
            padding: 2rem;
            box-shadow: 0 14px 32px rgba(59, 38, 24, 0.28);
            color: #fff;
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .customer-hero h2 {
            font-size: 2rem;
            margin: 0 0 0.6rem 0;
            letter-spacing: 0.3px;
            color: #fff;
        }

        .customer-hero p {
            margin: 0;
            max-width: 630px;
            color: rgba(255, 255, 255, 0.93);
        }

        .customer-badge {
            align-self: flex-start;
            background: rgba(255, 255, 255, 0.18);
            border: 1px solid rgba(255, 255, 255, 0.35);
            border-radius: 999px;
            padding: 0.45rem 0.9rem;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .customer-stat-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
        }

        .customer-stat-card {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #ebe5df;
            padding: 1.15rem;
            box-shadow: 0 8px 20px rgba(41, 28, 18, 0.08);
        }

        .customer-stat-label {
            color: #7a6a5f;
            font-size: 0.86rem;
            margin-bottom: 0.45rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .customer-stat-value {
            color: #3e2723;
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0;
        }

        .customer-stat-meta {
            margin-top: 0.35rem;
            color: #907c6c;
            font-size: 0.83rem;
        }

        .customer-section-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 1rem;
            min-height: 0;
        }

        .customer-panel {
            background: #fff;
            border: 1px solid #ece6e0;
            border-radius: 14px;
            box-shadow: 0 8px 22px rgba(41, 28, 18, 0.07);
            padding: 1.2rem;
        }

        .customer-panel h3 {
            margin: 0 0 1rem 0;
            color: #3e2723;
            font-size: 1.08rem;
        }

        .customer-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .customer-action-link {
            text-decoration: none;
            background: #f8f5f2;
            border: 1px solid #e8dfd6;
            border-radius: 12px;
            padding: 0.95rem;
            color: #4a3428;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            transition: all 0.2s ease;
            font-weight: 600;
        }

        .customer-action-link i {
            color: #8b4513;
            font-size: 1rem;
        }

        .customer-action-link:hover {
            transform: translateY(-2px);
            border-color: #d9c8b9;
            box-shadow: 0 8px 16px rgba(62, 39, 35, 0.1);
        }

        .customer-action-link button {
            background: transparent;
            border: none;
            color: inherit;
            font: inherit;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            width: 100%;
            text-align: left;
            cursor: pointer;
            padding: 0;
        }

        .customer-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(30, 18, 10, 0.55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            padding: 1rem;
        }

        .customer-modal-backdrop.show {
            display: flex;
        }

        .customer-order-modal {
            width: min(500px, 100%);
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e8ddd4;
            box-shadow: 0 20px 45px rgba(55, 32, 17, 0.25);
            padding: 1.3rem;
        }

        .customer-order-modal h4 {
            margin: 0 0 0.35rem 0;
            color: #3e2723;
            font-size: 1.12rem;
        }

        .customer-order-modal p {
            margin: 0 0 1rem 0;
            color: #7d695a;
            font-size: 0.9rem;
        }

        .customer-order-field {
            margin-bottom: 0.9rem;
        }

        .customer-order-field label {
            display: block;
            color: #513a2c;
            font-weight: 600;
            margin-bottom: 0.45rem;
        }

        .customer-order-field select,
        .customer-order-field input {
            width: 100%;
            border-radius: 10px;
            border: 1px solid #dccdbf;
            padding: 0.65rem 0.75rem;
            font-size: 0.92rem;
        }

        .customer-order-modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 0.55rem;
            margin-top: 1.1rem;
        }

        .customer-order-modal-actions button {
            border: none;
            border-radius: 10px;
            padding: 0.62rem 1rem;
            font-weight: 600;
            cursor: pointer;
        }

        .customer-order-cancel {
            background: #efe8e2;
            color: #5f4a3d;
        }

        .customer-order-submit {
            background: #8b4513;
            color: #fff;
        }

        .customer-activity-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0.7rem;
        }

        .customer-activity-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.9rem;
            padding: 0.8rem 0.85rem;
            border-radius: 10px;
            background: #faf8f6;
            border: 1px solid #ede6df;
        }

        .customer-activity-item strong {
            color: #463126;
            font-size: 0.93rem;
            display: block;
            margin-bottom: 0.2rem;
        }

        .customer-activity-item span {
            color: #887568;
            font-size: 0.8rem;
        }

        .customer-status {
            font-size: 0.73rem;
            padding: 0.28rem 0.58rem;
            border-radius: 999px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            white-space: nowrap;
        }

        .customer-status.ready {
            color: #0c6b43;
            background: #e4f6ee;
        }

        .customer-status.pending {
            color: #8c6410;
            background: #fff5db;
        }

        .customer-status.completed {
            color: #19586f;
            background: #e4f3f8;
        }

        @media (max-width: 1024px) {
            .customer-stat-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .customer-section-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 640px) {
            .customer-hero {
                padding: 1.4rem;
            }

            .customer-hero h2 {
                font-size: 1.45rem;
            }

            .customer-stat-grid,
            .customer-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block main_content %}
    <section class="customer-dashboard">
        <div class="customer-hero">
            <div>
                <h2>Welcome back, {{ app.user.username|format_username }}!</h2>
                <p>
                    Your dashboard gives you a clear view of orders, rewards, and your cafe activity.
                    Start from quick actions below and keep your favorites one click away.
                </p>
            </div>
            <span class="customer-badge"><i class="fas fa-mug-hot"></i> Customer Portal</span>
        </div>

        <div class="customer-stat-grid">
            <article class="customer-stat-card">
                <p class="customer-stat-label"><i class="fas fa-receipt"></i> Orders This Month</p>
                <p class="customer-stat-value">12</p>
                <p class="customer-stat-meta">+3 compared with last month</p>
            </article>
            <article class="customer-stat-card">
                <p class="customer-stat-label"><i class="fas fa-coins"></i> Reward Points</p>
                <p class="customer-stat-value">860</p>
                <p class="customer-stat-meta">140 points until your next voucher</p>
            </article>
            <article class="customer-stat-card">
                <p class="customer-stat-label"><i class="fas fa-star"></i> Favorite Drink</p>
                <p class="customer-stat-value">Caramel Latte</p>
                <p class="customer-stat-meta">Ordered 5 times this month</p>
            </article>
            <article class="customer-stat-card">
                <p class="customer-stat-label"><i class="fas fa-truck"></i> Current Order</p>
                <p class="customer-stat-value">In Progress</p>
                <p class="customer-stat-meta">Estimated ready in 8 minutes</p>
            </article>
        </div>

        <div class="customer-section-grid">
            <div class="customer-panel">
                <h3>Quick Actions</h3>
                <div class="customer-actions">
                    <a href="{{ path('app_products_menu') }}" class="customer-action-link">
                        <i class="fas fa-utensils"></i>
                        <span>Browse Menu</span>
                    </a>
                    <div class="customer-action-link">
                        <button type="button" id="open-customer-order-modal">
                            <i class="fas fa-shopping-cart"></i>
                            <span>Order Now</span>
                        </button>
                    </div>
                    <a href="{{ path('app_profile_index') }}" class="customer-action-link">
                        <i class="fas fa-user-circle"></i>
                        <span>View Profile</span>
                    </a>
                    <a href="{{ path('app_profile_change_password') }}" class="customer-action-link">
                        <i class="fas fa-lock"></i>
                        <span>Security Settings</span>
                    </a>
                </div>
            </div>

            <div class="customer-panel">
                <h3>Brewed Fresh, Served with Vibes</h3>
                <ul class="customer-activity-list">
                    <li class="customer-activity-item">
                        <strong>Where Every Sip Feels Like Home</strong>
                    </li>
                    <li class="customer-activity-item">
                        <strong>Crafted Cups, Cozy Moments</strong>
                    </li>
                    <li class="customer-activity-item">
                        <strong>Your Daily Dose of Coffee Bliss</strong>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <div class="customer-modal-backdrop" id="customer-order-modal-backdrop" aria-hidden="true">
        <div class="customer-order-modal" role="dialog" aria-modal="true" aria-labelledby="customer-order-modal-title">
            <h4 id="customer-order-modal-title">Place Your Order</h4>
            <p>Choose a product from the current list and submit your order.</p>
            <form method="post" action="{{ path('app_customer_orders_place') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('customer-order-place') }}">

                <div class="customer-order-field">
                    <label for="customer-order-product">Available Products</label>
                    <select id="customer-order-product" name="product_id" required>
                        <option value="">Select a product</option>
                        <optgroup label="Our Best Sellers">
                            <option value="Iced Latte">Iced Latte</option>
                            <option value="Caramel Macchiato">Caramel Macchiato</option>
                            <option value="Mocha">Mocha</option>
                            <option value="Cappuccino">Cappuccino</option>
                            <option value="Americano">Americano</option>
                            <option value="Frappuccino">Frappuccino</option>
                            <option value="Vanilla Latte">Vanilla Latte</option>
                            <option value="Hazelnut Cold Brew">Hazelnut Cold Brew</option>
                        </optgroup>
                        <optgroup label="Tea &amp; Non-Coffee">
                            <option value="Thai Tea">Thai Tea</option>
                            <option value="Chai Tea">Chai Tea</option>
                            <option value="Matcha Latte">Matcha Latte</option>
                            <option value="Hot Chocolate">Hot Chocolate</option>
                            <option value="Herbal Tea">Herbal Tea</option>
                        </optgroup>
                        <optgroup label="Pastries &amp; Snacks">
                            <option value="Croissant">Croissant</option>
                            <option value="Blueberry Muffin">Blueberry Muffin</option>
                            <option value="Chocolate Cookie">Chocolate Cookie</option>
                            <option value="Avocado Toast">Avocado Toast</option>
                        </optgroup>
                    </select>
                </div>

                <div class="customer-order-field">
                    <label for="customer-order-quantity">Quantity</label>
                    <input id="customer-order-quantity" type="number" name="quantity" min="1" value="1" required>
                </div>

                <div class="customer-order-modal-actions">
                    <button type="button" class="customer-order-cancel" id="close-customer-order-modal">Cancel</button>
                    <button type="submit" class="customer-order-submit">Place Order</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const openBtn = document.getElementById('open-customer-order-modal');
            const closeBtn = document.getElementById('close-customer-order-modal');
            const backdrop = document.getElementById('customer-order-modal-backdrop');
            const productSelect = document.getElementById('customer-order-product');

            if (!openBtn || !closeBtn || !backdrop || !productSelect) {
                return;
            }

            const closeModal = () => {
                backdrop.classList.remove('show');
                backdrop.setAttribute('aria-hidden', 'true');
            };

            openBtn.addEventListener('click', () => {
                backdrop.classList.add('show');
                backdrop.setAttribute('aria-hidden', 'false');
            });

            closeBtn.addEventListener('click', closeModal);

            backdrop.addEventListener('click', (event) => {
                if (event.target === backdrop) {
                    closeModal();
                }
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && backdrop.classList.contains('show')) {
                    closeModal();
                }
            });
        })();
    </script>
{% endblock %}
