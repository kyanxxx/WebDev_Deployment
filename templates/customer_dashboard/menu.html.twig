{% extends 'base.html.twig' %}

{% block title %}Harvey's Café - Menu / Products{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .menu-section {
            padding: 30px;
        }

        .menu-section h2 {
            font-size: 28px;
            color: #3E2723;
            margin-bottom: 30px;
            font-weight: 600;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 40px;
            max-width: 1400px;
        }

        .menu-card {
            background: white;
            border: 2px solid #8B5A3C;
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(139, 90, 60, 0.25);
        }

        .menu-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 2px solid #8B5A3C;
        }

        .menu-card-content {
            padding: 20px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .menu-card .menu-card-content h3 {
            margin: 0 0 10px 0;
        }

        .menu-card .menu-card-content > p:not(.price) {
            margin: 0 0 15px 0;
        }

        .menu-card h3 {
            font-size: 20px;
            color: #3E2723;
            margin: 0 0 10px 0;
            font-weight: 600;
        }

        .menu-card p {
            font-size: 14px;
            color: #666;
            margin: 0 0 15px 0;
            line-height: 1.5;
            flex-grow: 1;
        }

        .menu-card .price {
            font-size: 22px;
            color: #8B5A3C;
            font-weight: 700;
            margin: 0;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .menu-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @media (max-width: 768px) {
            .menu-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }

            .menu-card img {
                height: 150px;
            }
        }

        @media (max-width: 480px) {
            .menu-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard">
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <div class="logo-title">
                <img src="{{ asset('img/Logo.png') }}" alt="Cafe Logo" class="cafe-logo">
                <h1>Menu / Products</h1>
            </div>
            <div class="user-info">
                <span>Welcome, {{ app.user.username|format_username }}!</span>
                <i class="fas fa-user-circle"></i>
            </div>
        </div>
    </header>

    <div class="content-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <nav>
                <ul>
                    <li><a href="{{ path('app_customer_index') }}"><i class="fas fa-home"></i> Dashboard</a></li>
                    <li><a href="#" class="active"><i class="fas fa-utensils"></i> Menu / Products</a></li>
                    <li><a href="{{ path('app_products_index') }}"><i class="fas fa-shopping-cart"></i> Order Now</a></li>
                    <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main -->
        <main class="main">
            <section class="menu-section">
                {% for section in menuSections %}
                    <h2{% if not loop.first %} style="margin-top: 36px;"{% endif %}>{{ section.title }}</h2>
                    <div class="menu-grid">
                        {% for item in section.items %}
                            <div class="menu-card">
                                <img src="{{ asset('img/' ~ item.image) }}" alt="{{ item.name }}">
                                <div class="menu-card-content">
                                    <h3>{{ item.name }}</h3>
                                    <p>{{ item.description }}</p>
                                    <p class="price">${{ item.price|number_format(2) }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            </section>
        </main> 
    </div>
</div>
{% endblock %}
