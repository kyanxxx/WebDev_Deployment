{% extends 'base.html.twig' %}

{% block title %}Cafe Login{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Reset margins and padding for login page */
        body.login-page {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
            overflow-y: auto;
            min-height: 100vh;
        }
        
        .login-page-wrapper {
            background: linear-gradient(135deg, #823f08ff 0%, #3E2723 100%);
            min-height: 100vh;
            width: 100%;
            max-width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px 20px 4.5rem;
            margin: 0;
            box-sizing: border-box;
        }
        
        .login-page-wrapper .login-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            max-width: 420px;
            width: 100%;
        }
        
        .login-page-wrapper .login-header {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }
        
        .login-page-wrapper .coffee-icon {
            font-size: 48px;
            margin-bottom: 15px;
        }
        
        .login-page-wrapper .login-header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: white;
        }
        
        .login-page-wrapper .login-header p {
            margin: 8px 0 0 0;
            opacity: 0.9;
            font-size: 14px;
        }
        
        .login-page-wrapper .login-body {
            padding: 40px 30px;
        }
        
        .login-page-wrapper .alert {
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            border: none;
        }
        
        .login-page-wrapper .alert-danger {
            background-color: #fee;
            color: #c33;
        }
        
        .login-page-wrapper .alert-info {
            background-color: #e3f2fd;
            color: #1976d2;
            border-left: 4px solid #1976d2;
        }

        .login-page-wrapper .alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }

        .login-page-wrapper .alert-success .alert-success-inner {
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .login-page-wrapper .alert-success .alert-success-inner i {
            color: #1e7e34;
            margin-top: 2px;
            flex-shrink: 0;
        }

        .login-page-wrapper .alert-dismiss {
            background: none;
            border: none;
            color: #155724;
            cursor: pointer;
            font-size: 1.25rem;
            line-height: 1;
            padding: 0 4px;
            flex-shrink: 0;
        }

        .login-page-wrapper .alert-dismiss:hover {
            color: #0d3d18;
        }
        
        .login-page-wrapper .form-group {
            margin-bottom: 20px;
        }
        
        .login-page-wrapper .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #4a4a4a;
            font-weight: 500;
            font-size: 14px;
        }
        
        .login-page-wrapper .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        
        .login-page-wrapper .form-control:focus {
            outline: none;
            border-color: #8B5A3C;
            box-shadow: 0 0 0 3px rgba(139, 90, 60, 0.1);
        }
        
        .login-page-wrapper .checkbox-container {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }
        
        .login-page-wrapper .checkbox-container input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            cursor: pointer;
        }
        
        .login-page-wrapper .checkbox-container label {
            margin: 0;
            color: #666;
            font-size: 14px;
            cursor: pointer;
        }
        
        .login-page-wrapper .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .login-page-wrapper .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139, 90, 60, 0.3);
        }
        
        .login-page-wrapper .btn-submit:active {
            transform: translateY(0);
        }

        .login-page-wrapper .oauth-divider {
            margin: 18px 0 14px;
            text-align: center;
            color: #777;
            font-size: 13px;
            position: relative;
        }

        .login-page-wrapper .oauth-divider::before,
        .login-page-wrapper .oauth-divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 36%;
            height: 1px;
            background: #ddd;
        }

        .login-page-wrapper .oauth-divider::before {
            left: 0;
        }

        .login-page-wrapper .oauth-divider::after {
            right: 0;
        }

        .login-page-wrapper .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 10px;
            background: #fff;
            color: #444;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            transition: background-color 0.2s ease, border-color 0.2s ease;
        }

        .login-page-wrapper .btn-google:hover {
            background: #f8f8f8;
            border-color: #cfcfcf;
        }

        .login-page-wrapper .google-icon {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
        }
        
        .login-page-wrapper .logout-link {
            color: #8B5A3C;
            text-decoration: none;
            font-weight: 500;
        }
        
        .login-page-wrapper .logout-link:hover {
            text-decoration: underline;
        }

        .login-page-wrapper .register-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #8B5A3C;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            transition: color 0.2s ease;
        }
        
        .login-page-wrapper .register-link:hover {
            text-decoration: underline;
            color: #6B4423;
        }

        .logo-container img {
        width: 130px;   /* change size here */
        height: auto;   /* keeps the image proportion */
        }

    </style>
{% endblock %}

{% block body %}
<script>
    document.body.classList.add('login-page');
</script>
<div class="login-page-wrapper">
    <div class="login-container">
        <div class="login-header">     
                <div class="logo-container">
                    <img src="img/Logo.png" alt="Harvey's Cafe">
                </div>

            <h1>Welcome Back</h1>
            <p>Sign in to your cafe account</p>
        </div>
        
        <div class="login-body">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success flash-message" role="alert">
                    <span class="alert-success-inner">
                        <span>{{ message }}</span>
                    </span>
                </div>
            {% endfor %}

            {% if error %}
                <div class="alert alert-danger">
                    {{ error }}
                </div>
            {% endif %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger flash-message">
                    {{ message }}
                </div>
            {% endfor %}

            {% if app.user %}
                <div class="alert alert-info">
                    You are logged in as <strong>{{ app.user.userIdentifier }}</strong>. 
                    <a href="{{ path('app_logout') }}" class="logout-link">Logout</a>
                </div>
            {% endif %}

            <form method="post" data-turbo="false">
                <div class="form-group">
                    <label for="inputUsername">Username</label>
                    <input type="text" 
                           value="{{ last_username }}" 
                           name="username" 
                           id="inputUsername" 
                           class="form-control" 
                           autocomplete="username" 
                           required 
                           autofocus
                           placeholder="Enter your username">
                </div>

                <div class="form-group">
                    <label for="inputPassword">Password</label>
                    <input type="password" 
                           name="password" 
                           id="inputPassword" 
                           class="form-control" 
                           autocomplete="current-password" 
                           required
                           placeholder="Enter your password">
                </div>

                <input type="hidden" 
                       name="_csrf_token" 
                       value="{{ csrf_token('authenticate') }}">

                <div class="checkbox-container">
                    <input type="checkbox" name="_remember_me" id="rememberMe">
                    <label for="rememberMe">Remember me</label>
                </div>

                <button class="btn-submit" type="submit">
                    Sign in to Cafe
                </button>
            </form>

            <div class="oauth-divider">or</div>
            <a href="{{ path('connect_google_start') }}" class="btn-google">
                <svg class="google-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.2-2.27H12v4.29h6.44a5.5 5.5 0 0 1-2.39 3.61v3h3.87c2.26-2.08 3.57-5.15 3.57-8.63z"/>
                    <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.95-2.91l-3.87-3c-1.07.72-2.43 1.15-4.08 1.15-3.13 0-5.78-2.11-6.73-4.95H1.28v3.09A12 12 0 0 0 12 24z"/>
                    <path fill="#FBBC05" d="M5.27 14.29A7.2 7.2 0 0 1 4.9 12c0-.8.14-1.58.37-2.29V6.62H1.28A12 12 0 0 0 0 12c0 1.94.46 3.77 1.28 5.38l3.99-3.09z"/>
                    <path fill="#EA4335" d="M12 4.77c1.76 0 3.35.61 4.6 1.82l3.45-3.45C17.95 1.15 15.24 0 12 0A12 12 0 0 0 1.28 6.62l3.99 3.09c.95-2.84 3.6-4.94 6.73-4.94z"/>
                </svg>
                <span>Continue with Google</span>
            </a>
            
            <a href="{{ path('app_register') }}" class="register-link">Don't have an account?</a>
        </div>
    </div>
</div>
{% endblock %}