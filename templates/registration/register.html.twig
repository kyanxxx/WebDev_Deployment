{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Reset margins and padding for register page */
        body.register-page {
            margin: 0 !important;
            padding: 0 !important;
            overflow-x: hidden;
            overflow-y: auto;
            min-height: 100vh;
        }
        
        .register-page-wrapper {
            background: linear-gradient(135deg, #823f08ff 0%, #3E2723 100%);
            min-height: 100vh;
            width: 100%;
            max-width: 100vw;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px 20px 4.5rem;
            margin: 0;
            box-sizing: border-box;
        }
        
        .register-page-wrapper .register-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            max-width: 420px;
            width: 100%;
        }
        
        .register-page-wrapper .register-header {
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }
        
        .register-page-wrapper .register-header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 600;
            letter-spacing: 0.5px;
            color: white;
        }
        
        .register-page-wrapper .register-header p {
            margin: 8px 0 0 0;
            opacity: 0.9;
            font-size: 14px;
        }
        
        .register-page-wrapper .register-body {
            padding: 40px 30px;
        }
        
        .register-page-wrapper .alert {
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 20px;
            border: none;
        }
        
        .register-page-wrapper .alert-danger {
            background-color: #fee;
            color: #c33;
        }
        
        .register-page-wrapper .form-group {
            margin-bottom: 20px;
        }
        
        .register-page-wrapper .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #4a4a4a;
            font-weight: 500;
            font-size: 14px;
        }
        
        .register-page-wrapper .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }
        
        .register-page-wrapper .form-control:focus {
            outline: none;
            border-color: #8B5A3C;
            box-shadow: 0 0 0 3px rgba(139, 90, 60, 0.1);
        }
        
        .register-page-wrapper .checkbox-container {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }
        
        .register-page-wrapper .checkbox-container input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            cursor: pointer;
        }
        
        .register-page-wrapper .checkbox-container label {
            margin: 0;
            color: #666;
            font-size: 14px;
            cursor: pointer;
        }
        
        .register-page-wrapper .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #8B5A3C 0%, #6B4423 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .register-page-wrapper .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139, 90, 60, 0.3);
        }
        
        .register-page-wrapper .btn-submit:active {
            transform: translateY(0);
        }
        
        .register-page-wrapper .login-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #8B5A3C;
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            transition: color 0.2s ease;
        }
        
        .register-page-wrapper .login-link:hover {
            text-decoration: underline;
            color: #6B4423;
        }

        .logo-container img {
            width: 130px;
            height: auto;
        }
    </style>
{% endblock %}

{% block body %}
<script>
    document.body.classList.add('register-page');
    
    // Prevent CSRF protection JavaScript from modifying our form token
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form[data-turbo="false"]');
        if (form) {
            // Find and protect the CSRF token field
            const tokenField = form.querySelector('input[name*="_token"]');
            if (tokenField) {
                // Store the original value
                const originalValue = tokenField.value;
                
                // Prevent the CSRF controller from modifying it
                tokenField.setAttribute('data-csrf-protection', 'disabled');
                
                // Restore original value before submit if it was changed
                form.addEventListener('submit', function(e) {
                    if (tokenField.value !== originalValue) {
                        tokenField.value = originalValue;
                    }
                }, false);
            }
        }
    }, false);
</script>
<div class="register-page-wrapper">
    <div class="register-container">
        <div class="register-header">
            <div class="logo-container">
                <img src="img/Logo.png" alt="Harvey's Cafe">
            </div>
            <h1>Register</h1>
            <p>Create your account to get started</p>
        </div>
        
        <div class="register-body">
            {% if form_errors(registrationForm) %}
                <div class="alert alert-danger">
                    {{ form_errors(registrationForm) }}
                </div>
            {% endif %}

            {{ form_start(registrationForm, {
                'attr': {
                    'data-turbo': 'false',
                    'data-csrf-protection': 'false'
                }
            }) }}
                <div class="form-group">
                    {{ form_label(registrationForm.username, 'Username') }}
                    {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': 'Enter your username'}}) }}
                    {{ form_errors(registrationForm.username) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.email, 'Email') }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email address'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword, 'Password') }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Create a strong password'}}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                <div class="checkbox-container">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms, 'I agree to the terms and conditions') }}
                </div>
                {{ form_errors(registrationForm.agreeTerms) }}

                <button type="submit" class="btn-submit">Register</button>
            {{ form_end(registrationForm) }}

            <a href="{{ path('app_login') }}" class="login-link">Already have an account?</a>
        </div>
    </div>
</div>
{% endblock %}