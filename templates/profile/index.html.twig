{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block page_title %}My Profile{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .profile-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            padding: 40px;
            margin-bottom: 30px;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e0e0e0;
        }

        .profile-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6b4e31 0%, #8b4513 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
            font-weight: bold;
        }

        .profile-info h2 {
            margin: 0 0 5px 0;
            color: #6b4e31;
            font-size: 1.8rem;
        }

        .profile-info p {
            margin: 0;
            color: #6c757d;
            font-size: 1rem;
        }

        .profile-details {
            display: grid;
            gap: 20px;
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: #f8f9fa;
            border-radius: 8px;
        }

        .detail-label {
            font-weight: 600;
            color: #6b4e31;
        }

        .detail-value {
            color: #333;
        }

        .role-badge {
            display: inline-block;
            padding: 6px 15px;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .role-ROLE_ADMIN {
            background: #6b4e31;
            color: white;
        }

        .role-ROLE_STAFF {
            background: #8b4513;
            color: white;
        }

        .role-ROLE_USER {
            background: #6c757d;
            color: white;
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn-primary {
            background: #6b4e31;
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            display: inline-block;
            font-weight: 500;
            transition: background 0.3s;
        }

        .btn-primary:hover {
            background: #8b4513;
        }

        @media (max-width: 768px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
            }

            .action-buttons {
                flex-direction: column;
            }

            .btn-primary {
                width: 100%;
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block main_content %}
<div class="profile-container">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-message flash-{{ label }}" style="background: {% if label == 'success' %}#d4edda; color: #155724; border: 1px solid #c3e6cb;{% elseif label == 'error' %}#f8d7da; color: #721c24; border: 1px solid #f5c6cb;{% else %}#d1ecf1; color: #0c5460; border: 1px solid #bee5eb;{% endif %} padding: 15px 20px; margin-bottom: 20px; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                <span>{% if label != 'success' %}<i class="fas fa-{% if label == 'error' %}exclamation-circle{% else %}info-circle{% endif %}"></i> {% endif %}{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}
    
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ user.username|first|upper }}
            </div>
            <div class="profile-info">
                <h2>{{ user.username }}</h2>
                <p>Account Profile</p>
            </div>
        </div>

        <div class="profile-details">
            <div class="detail-item">
                <span class="detail-label">Username:</span>
                <span class="detail-value">{{ user.username }}</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">User ID:</span>
                <span class="detail-value">#{{ user.id }}</span>
            </div>

            <div class="detail-item">
                <span class="detail-label">Role:</span>
                <span class="detail-value">
                    {% if user.isAdmin() %}
                        <span class="role-badge role-ROLE_ADMIN">Administrator</span>
                    {% elseif user.isStaff() %}
                        <span class="role-badge role-ROLE_STAFF">Staff</span>
                    {% else %}
                        <span class="role-badge role-ROLE_USER">User</span>
                    {% endif %}
                </span>
            </div>

            <div class="detail-item">
                <span class="detail-label">All Roles:</span>
                <span class="detail-value">
                    {% for role in user.roles %}
                        {% if role != 'ROLE_USER' %}
                            <span class="role-badge role-{{ role }}">{{ role }}</span>
                        {% endif %}
                    {% endfor %}
                </span>
            </div>
        </div>

        <div class="action-buttons">
            <a href="{{ path('app_profile_change_password') }}" class="btn-primary">
                <i class="fas fa-key"></i> Change Password
            </a>
            <a href="{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}{{ path('app_dashboard') }}{% else %}{{ path('app_customer_index') }}{% endif %}" class="btn-primary" style="background: #6c757d;">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>
{% endblock %}

